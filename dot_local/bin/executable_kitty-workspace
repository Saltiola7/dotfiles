#!/bin/bash
#
# kitty-workspace - Open or focus a project workspace in Kitty
#
# Called from PyCharm External Tool (or anywhere) with a project directory.
#
# Behavior:
#   1. Derives workspace name from directory basename
#   2. Checks if a Kitty OS window already has this workspace
#      - Found: focuses that OS window and brings Kitty to foreground
#      - Not found: builds the workspace from the hardcoded definition,
#        then restores extra tabs from a snapshot if one exists
#
# Usage:
#   kitty-workspace /path/to/project
#   kitty-workspace                    # uses current directory
#   kitty-workspace --validate         # check prerequisites without executing
#
# Debugging:
#   KITTY_WORKSPACE_DEBUG=1 kitty-workspace /path/to/project
#   tail -f ~/.local/share/kitty/workspace.log
#
# Dependencies:
#   - kitty-query.py (installed via chezmoi to ~/.config/kitty/kitty-query.py)
#   - uv (for running kitty-query.py with inline dependencies)

set -uo pipefail
trap 'echo "kitty-workspace: error on line $LINENO" >&2' ERR

# ── Shared tooling ──

KQ="$HOME/.config/kitty/kitty-query.py"
KITTY="$(command -v kitty || true)"
SESSIONS_DIR="$HOME/.config/kitty/sessions"
OC_STORAGE="$HOME/.local/share/opencode-kitty"
LOG_FILE="$HOME/.local/share/kitty/workspace.log"
LOCK_DIR="/tmp/kitty-workspace.lock"
SOCKET_GLOB="$HOME/.local/share/kitty/control-socket-*"

log() {
    [[ "${KITTY_WORKSPACE_DEBUG:-}" == "1" ]] || return 0
    echo "[$(date '+%H:%M:%S')] kitty-workspace: $*" >> "$LOG_FILE"
}

_find_socket() { ls $SOCKET_GLOB 2>/dev/null | head -1 || true; }

# ── Validate mode ──

if [[ "${1:-}" == "--validate" ]]; then
    echo "kitty-workspace prerequisites:"

    # kitty binary
    if [[ -n "$KITTY" && -x "$KITTY" ]]; then
        echo "  [OK] kitty binary: $KITTY"
    else
        echo "  [FAIL] kitty binary: not found on PATH"
    fi

    # uv
    _uv=$(command -v uv || true)
    if [[ -n "$_uv" ]]; then
        echo "  [OK] uv: $_uv"
    else
        echo "  [FAIL] uv: not found on PATH"
    fi

    # kitty-query.py
    if [[ -f "$KQ" ]]; then
        echo "  [OK] kitty-query: $KQ"
    else
        echo "  [FAIL] kitty-query: $KQ (not found)"
    fi

    # kitty socket
    _socket=$(_find_socket)
    if [[ -n "$_socket" ]]; then
        echo "  [OK] kitty socket: $_socket"
    else
        echo "  [WARN] kitty socket: not found (kitty not running -- will auto-launch)"
    fi

    # kitty remote control
    if [[ -n "$_socket" && -n "$KITTY" ]]; then
        if $KITTY @ --to=unix:"$_socket" ls &>/dev/null; then
            echo "  [OK] kitty remote control: responding"
        else
            echo "  [FAIL] kitty remote control: not responding on $_socket"
        fi
    fi

    # sessions dir
    if [[ -d "$SESSIONS_DIR" ]]; then
        echo "  [OK] sessions dir: $SESSIONS_DIR"
    else
        echo "  [WARN] sessions dir: $SESSIONS_DIR (does not exist yet)"
    fi

    # opencode-kitty
    _ock=$(command -v opencode-kitty || true)
    if [[ -n "$_ock" && -x "$_ock" ]]; then
        echo "  [OK] opencode-kitty: $_ock"
    else
        echo "  [FAIL] opencode-kitty: not found on PATH"
    fi

    # opencode
    _oc=$(command -v opencode || true)
    if [[ -n "$_oc" ]]; then
        echo "  [OK] opencode: $_oc"
    else
        echo "  [FAIL] opencode: not found on PATH"
    fi

    # python3
    _py=$(command -v python3 || true)
    if [[ -n "$_py" ]]; then
        echo "  [OK] python3: $_py"
    else
        echo "  [FAIL] python3: not found on PATH"
    fi

    # socket directory
    if [[ -d "$HOME/.local/share/kitty" ]]; then
        echo "  [OK] socket dir: $HOME/.local/share/kitty"
    else
        echo "  [FAIL] socket dir: $HOME/.local/share/kitty (missing -- run chezmoi apply)"
    fi

    # secret function (check if it's defined in a login shell)
    if bash -l -c 'type secret' &>/dev/null; then
        echo "  [OK] secret(): available in login shell"
    else
        echo "  [FAIL] secret(): not found in login shell"
    fi

    exit 0
fi

# ── Find the kitty remote control socket (start kitty if needed) ──

if [[ -z "$KITTY" ]]; then
    echo "Error: kitty not found on PATH" >&2
    exit 1
fi

# Prevent concurrent execution (race condition: multiple hotkey presses)
cleanup_lock() { rmdir "$LOCK_DIR" 2>/dev/null || true; }
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
    # Another instance is running. Check if it's stale (>30s old).
    if [[ -d "$LOCK_DIR" ]]; then
        lock_age=$(( $(date +%s) - $(stat -f %m "$LOCK_DIR" 2>/dev/null || echo 0) ))
        if [[ "$lock_age" -gt 30 ]]; then
            rmdir "$LOCK_DIR" 2>/dev/null || true
            mkdir "$LOCK_DIR" 2>/dev/null || { log "Lock contention, exiting"; exit 0; }
        else
            log "Another instance running (lock age=${lock_age}s), exiting"
            exit 0
        fi
    fi
fi
trap cleanup_lock EXIT

log "Starting: args=$*"

SOCKET=$(_find_socket)
LAUNCHED_KITTY=false
DEFAULT_WIN=""
if [[ -z "$SOCKET" ]]; then
    log "No socket found, launching kitty..."
    open -a kitty
    for _i in {1..30}; do
        sleep 0.5
        SOCKET=$(_find_socket)
        [[ -n "$SOCKET" ]] && break
    done
    if [[ -z "$SOCKET" ]]; then
        echo "Error: Kitty started but socket not found after 15s." >&2
        echo "Is listen_on configured in kitty.conf?" >&2
        exit 1
    fi
    LAUNCHED_KITTY=true
    # Capture the default startup window so we can close it after workspace creation
    DEFAULT_WIN=$($KITTY @ --to=unix:$SOCKET ls 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
for oswin in data:
    for tab in oswin.get('tabs', []):
        for win in tab.get('windows', []):
            print(win['id'])
            sys.exit(0)
" 2>/dev/null || true)
    log "Kitty launched, socket: $SOCKET, default_win: $DEFAULT_WIN"
else
    log "Socket: $SOCKET"
fi

KITTY_RC="$KITTY @ --to=unix:$SOCKET"

# ── Resolve project directory and workspace name ──

PROJECT_DIR="${1:-$(pwd)}"
BASENAME="$(basename "$PROJECT_DIR")"
log "Project: $PROJECT_DIR ($BASENAME)"

# ── Check if workspace OS window already exists ──

OSWIN_ID=$($KITTY_RC ls 2>/dev/null | uv run --script "$KQ" find-oswin "$BASENAME" 2>/dev/null || true)

if [[ -n "$OSWIN_ID" ]]; then
    log "Existing workspace found (os_window=$OSWIN_ID), focusing"
    $KITTY_RC focus-window --match "var:workspace=$BASENAME" 2>/dev/null || true
    open -a kitty
    exit 0
fi

log "No existing workspace, creating new one"

# ── Helpers ──

# Create the initial OS window, return first window ID
create_os_window() {
    local cwd="$1"
    local tab_title="$2"
    local win_id
    win_id=$($KITTY_RC launch --type=os-window --tab-title="$tab_title" --cwd="$cwd" \
        --var workspace="$BASENAME")
    if [[ -z "$win_id" ]]; then
        echo "Error: failed to create OS window for $tab_title" >&2
        log "ERROR: create_os_window failed (cwd=$cwd title=$tab_title)"
        exit 1
    fi
    log "Created OS window: win_id=$win_id title=$tab_title cwd=$cwd"
    echo "$win_id"
}

# Add a vsplit pane, return new window ID
add_vsplit() {
    local match_win="$1"
    local cwd="$2"
    shift 2
    local win_id
    win_id=$($KITTY_RC launch --match "window_id:$match_win" --location=vsplit --cwd="$cwd" "$@")
    log "Added vsplit: win_id=$win_id match=$match_win cwd=$cwd"
    echo "$win_id"
}

# Add a new tab, return new window ID
add_tab() {
    local match_win="$1"
    local tab_title="$2"
    local cwd="$3"
    shift 3
    local win_id
    win_id=$($KITTY_RC launch --type=tab --match "window_id:$match_win" \
        --tab-title="$tab_title" --cwd="$cwd" "$@")
    log "Added tab: win_id=$win_id title=$tab_title match=$match_win cwd=$cwd"
    echo "$win_id"
}

# Pre-type a command into a pane (no Enter -- user can review/edit first)
type_cmd() {
    local win_id="$1"
    local cmd="$2"
    sleep 0.3  # let the shell prompt render
    $KITTY_RC send-text --match "id:$win_id" "$cmd"
    log "Typed command in win_id=$win_id: $cmd"
}

# Seed opencode session IDs from snapshot for opencode-kitty to pick up
seed_opencode_sessions() {
    local snapshot="$SESSIONS_DIR/${BASENAME}.snapshot.conf"
    [[ -f "$snapshot" ]] || return 0

    mkdir -p "$OC_STORAGE"
    local seed_file="$OC_STORAGE/${BASENAME}.seed"

    # Extract opencode session IDs from the snapshot's opencode-kitty map
    local map_file="$OC_STORAGE/${BASENAME}.map"
    if [[ -f "$map_file" ]]; then
        # Save the session IDs (values) for the new panes to pick up
        grep -v '^#' "$map_file" 2>/dev/null | grep -v '^$' | cut -d= -f2 > "$seed_file" 2>/dev/null || true
        # Clear the stale map (old window IDs won't match new ones)
        rm -f "$map_file"
        log "Seeded from snapshot: $snapshot"
    fi
}

# ── Workspace definitions ──

build_seo-data-science() {
    local cwd="$HOME/MGM/git/seo-data-science"

    seed_opencode_sessions

    # Tab 1: servers (two panes: prefect + marimo)
    local win1 win2
    win1=$(create_os_window "$cwd" "servers")
    win2=$(add_vsplit "$win1" "$cwd")
    type_cmd "$win1" "mise run local-prefect"
    type_cmd "$win2" "marimo --watch notebooks/"

    # Tab 2: opencode
    add_tab "$win1" "opencode" "$cwd" bash -l -c "secret && exec opencode-kitty"

    # Focus servers tab
    $KITTY_RC focus-tab --match "title:^servers$" 2>/dev/null || true
    log "build_seo-data-science complete"
}

build_tsc() {
    local cwd="$HOME/github/tsc"

    seed_opencode_sessions

    # Tab 1: app (Django)
    local win1
    win1=$(create_os_window "$cwd" "app")
    type_cmd "$win1" "make start"

    # Tab 2: flowbite (two panes)
    local win2 win3
    win2=$(add_tab "$win1" "flowbite" "$HOME/github/flowbite/flowbite-admin-dashboard-v2.2.0")
    win3=$(add_vsplit "$win2" "$HOME/github/flowbite/flowbite-pro-marketing-ui-pages-main")
    type_cmd "$win2" "npm start"
    type_cmd "$win3" "npm start"

    # Tab 3: opencode
    add_tab "$win1" "opencode" "$cwd" bash -l -c "secret && exec opencode-kitty"

    # Focus app tab
    $KITTY_RC focus-tab --match "title:^app$" 2>/dev/null || true
    log "build_tsc complete"
}

build_dotfiles() {
    local cwd="$HOME/github/dotfiles"

    seed_opencode_sessions

    # Tab 1: shell
    local win1
    win1=$(create_os_window "$cwd" "shell")

    # Tab 2: opencode
    add_tab "$win1" "opencode" "$cwd" bash -l -c "secret && exec opencode-kitty"

    # Focus shell tab
    $KITTY_RC focus-tab --match "title:^shell$" 2>/dev/null || true
    log "build_dotfiles complete"
}

# ── Restore extra tabs from snapshot ──

# Base tab names per workspace (passed to kitty-query parse-extra-tabs-cmd)
# These must match the tabs created by the build_* functions above.
base_tabs_for() {
    case "$1" in
        seo-data-science) echo "servers opencode" ;;
        tsc)              echo "app flowbite opencode" ;;
        dotfiles)         echo "shell opencode" ;;
        *)                echo "$1 opencode" ;;  # generic fallback
    esac
}

restore_extra_tabs() {
    local snapshot="$SESSIONS_DIR/${BASENAME}.snapshot.conf"
    [[ -f "$snapshot" ]] || return 0

    # Find the first window ID in the workspace (to anchor new tabs)
    local first_win
    first_win=$($KITTY_RC ls 2>/dev/null | uv run --script "$KQ" find-win "$BASENAME" 2>/dev/null || true)

    [[ -n "$first_win" ]] || return 0

    log "Restoring extra tabs from $snapshot (anchor=$first_win)"

    # Parse snapshot for tabs not in the base definition
    local base
    base=$(base_tabs_for "$BASENAME")
    # shellcheck disable=SC2086
    uv run --script "$KQ" parse-extra-tabs-cmd "$snapshot" $base 2>/dev/null | while IFS='|' read -r title cwd cmd; do
        if [[ -n "$cmd" ]]; then
            $KITTY_RC launch --type=tab --match "window_id:$first_win" \
                --tab-title="$title" --cwd="$cwd" $cmd
        else
            $KITTY_RC launch --type=tab --match "window_id:$first_win" \
                --tab-title="$title" --cwd="$cwd"
        fi
        log "Restored extra tab: $title (cwd=$cwd)"
    done
}

# ── Dispatch ──

BUILD_FN="build_${BASENAME}"

if type "$BUILD_FN" &>/dev/null; then
    log "Dispatching: $BUILD_FN"
    "$BUILD_FN"
    restore_extra_tabs
else
    log "No build function for '$BASENAME', using generic fallback"
    # Fallback: generic workspace with shell tab + opencode tab
    seed_opencode_sessions

    win1=$(create_os_window "$PROJECT_DIR" "$BASENAME")
    add_tab "$win1" "opencode" "$PROJECT_DIR" bash -l -c "secret && exec opencode-kitty"

    # Focus shell tab
    $KITTY_RC focus-tab --match "title:^${BASENAME}$" 2>/dev/null || true
fi

# Close kitty's default startup window if we launched kitty fresh
if [[ "$LAUNCHED_KITTY" == "true" && -n "$DEFAULT_WIN" ]]; then
    $KITTY_RC close-window --match "id:$DEFAULT_WIN" 2>/dev/null || true
    log "Closed default startup window: $DEFAULT_WIN"
fi

open -a kitty
log "Done"
