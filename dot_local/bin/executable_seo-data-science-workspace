#!/bin/bash
#
# seo-workspace - Launch or attach to the SEO development zellij session
#
# Behavior:
#   1. If session is running, attach/switch to it
#   2. If a snapshot layout exists, use it (preserves your evolved pane structure)
#   3. Otherwise, use the base layout
#
# Works from outside zellij (attach) and inside zellij (switch-session).
#
# Tabs (base layout):
#   1. servers  - Prefect + Marimo
#   2. opencode - AI coding assistant (resumes last session)

set -euo pipefail

SESSION="seo-dev"
BASE_LAYOUT="$HOME/.config/zellij/layouts/seo-dev.kdl"
SNAPSHOT_DIR="$HOME/.local/share/opencode-zellij"
SNAPSHOT_LAYOUT="$SNAPSHOT_DIR/${SESSION}.snapshot.kdl"
SNAPSHOT_JSON="$SNAPSHOT_DIR/${SESSION}.snapshot.json"
MAP_FILE="$SNAPSHOT_DIR/${SESSION}.map"
INSIDE_ZELLIJ="${ZELLIJ:+true}"

# ── Helper: generate a temp layout that renames the session after startup ──
make_named_layout() {
  local layout="$1"
  local name="$2"
  local tmp_layout
  tmp_layout=$(mktemp /tmp/zellij-layout-XXXXXX.kdl)
  python3 -c "
with open('$layout') as f:
    content = f.read()
rename_block = '''
    floating_panes {
        pane command=\"bash\" close_on_exit=true {
            args \"-c\" \"sleep 0.5 && zellij action rename-session '$name'\"
        }
    }
'''
last_brace = content.rfind('}')
print(content[:last_brace] + rename_block + content[last_brace:])
" > "$tmp_layout"
  echo "$tmp_layout"
}

# ── Helper: launch or switch to session with a given layout ──
start_session() {
  local layout="$1"
  if [[ "$INSIDE_ZELLIJ" == "true" ]]; then
    # From inside zellij, -n creates a new session and switches to it.
    # We inject a floating pane that renames the session to our desired name.
    local tmp_layout
    tmp_layout=$(make_named_layout "$layout" "$SESSION")
    exec zellij --new-session-with-layout "$tmp_layout"
  else
    exec zellij --layout "$layout" attach --create "$SESSION"
  fi
}

# ── Helper: attach or switch to existing session ──
join_session() {
  if [[ "$INSIDE_ZELLIJ" == "true" ]]; then
    exec zellij action switch-session "$SESSION"
  else
    exec zellij attach "$SESSION"
  fi
}

# ── Check if the session already exists (running or resurrectable) ──

if zellij list-sessions --no-formatting 2>/dev/null | grep -q "^${SESSION} "; then
  echo "Attaching to existing zellij session: $SESSION"
  join_session
fi

# ── Restore pane-session bindings from snapshot if available ──

if [[ -f "$SNAPSHOT_JSON" && -f "$SNAPSHOT_LAYOUT" ]]; then
  echo "Found snapshot from: $(python3 -c "import json; print(json.load(open('$SNAPSHOT_JSON')).get('timestamp','unknown'))" 2>/dev/null || echo "unknown")"

  # Extract opencode session IDs from snapshot for restoration priority
  mkdir -p "$SNAPSHOT_DIR"
  python3 -c "
import json, sys
try:
    snap = json.load(open('$SNAPSHOT_JSON'))
    sessions = [p['opencode_session_id'] for p in snap.get('pane_mappings', []) if 'opencode_session_id' in p]
    with open('$SNAPSHOT_DIR/${SESSION}.seed', 'w') as f:
        for sid in sessions:
            f.write(sid + '\n')
    print(f'Seeded {len(sessions)} opencode session(s) for restoration')
except Exception as e:
    print(f'Warning: Could not read snapshot JSON: {e}', file=sys.stderr)
" 2>&1

  # Clear stale map (pane IDs from previous session won't match)
  rm -f "$MAP_FILE"

  echo "Creating session from snapshot layout: $SNAPSHOT_LAYOUT"
  start_session "$SNAPSHOT_LAYOUT"
fi

# ── No snapshot - use base layout ──

echo "Creating new zellij session from base layout: $BASE_LAYOUT"
start_session "$BASE_LAYOUT"
