#!/bin/bash
#
# zellij-snapshot - Capture current zellij layout and opencode session mappings
#
# Must be run from INSIDE a zellij session (uses zellij action commands).
#
# Produces:
#   ~/.local/share/opencode-zellij/{session}.snapshot.kdl  - Full layout (loadable by zellij)
#   ~/.local/share/opencode-zellij/{session}.snapshot.json - Pane-to-session mapping metadata
#
# Usage:
#   zellij-snapshot              # snapshot current session
#   zellij-snapshot --quiet      # suppress output (for keybinding use)

set -euo pipefail

STORAGE_DIR="$HOME/.local/share/opencode-zellij"
mkdir -p "$STORAGE_DIR"

QUIET=false
for arg in "$@"; do
  [[ "$arg" == "--quiet" ]] && QUIET=true
done

# ── Verify we're inside a zellij session ──

ZELLIJ_SESSION="${ZELLIJ_SESSION_NAME:-}"
if [[ -z "$ZELLIJ_SESSION" ]]; then
  echo "Error: Not inside a zellij session. ZELLIJ_SESSION_NAME is not set." >&2
  exit 1
fi

SNAPSHOT_KDL="$STORAGE_DIR/${ZELLIJ_SESSION}.snapshot.kdl"
SNAPSHOT_JSON="$STORAGE_DIR/${ZELLIJ_SESSION}.snapshot.json"
MAP_FILE="$STORAGE_DIR/${ZELLIJ_SESSION}.map"

# ── Step 1: Dump the current layout ──

if ! zellij action dump-layout > "$SNAPSHOT_KDL.tmp" 2>/dev/null; then
  echo "Error: Failed to dump layout. Is the zellij session alive?" >&2
  rm -f "$SNAPSHOT_KDL.tmp"
  exit 1
fi
mv "$SNAPSHOT_KDL.tmp" "$SNAPSHOT_KDL"

# ── Step 2: List all panes with metadata ──

PANES_JSON=""
if zellij action list-panes --json --all --command > /dev/null 2>&1; then
  PANES_JSON=$(zellij action list-panes --json --all --command 2>/dev/null || echo "[]")
else
  # Fallback: try without --command flag (older zellij versions)
  PANES_JSON=$(zellij action list-panes --json --all 2>/dev/null || echo "[]")
fi

# ── Step 3: Build the snapshot JSON with pane-session cross-reference ──

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Read the current map file into an associative structure for cross-referencing
# We'll use a simple approach: for each pane that runs opencode-zellij, look up its binding
MAP_ENTRIES=""
if [[ -f "$MAP_FILE" ]]; then
  MAP_ENTRIES=$(grep -v '^#' "$MAP_FILE" 2>/dev/null | grep -v '^$' || true)
fi

# Build the snapshot JSON using python3 (available on macOS) for reliable JSON handling
python3 -c "
import json
import sys

panes_raw = sys.argv[1]
map_entries_raw = sys.argv[2]
zellij_session = sys.argv[3]
timestamp = sys.argv[4]

# Parse panes JSON
try:
    panes = json.loads(panes_raw) if panes_raw else []
except (json.JSONDecodeError, TypeError):
    panes = []

# Parse map entries into a dict: pane_id -> opencode_session_id
pane_map = {}
for line in map_entries_raw.strip().split('\n'):
    if '=' in line:
        pid, sid = line.split('=', 1)
        pane_map[pid.strip()] = sid.strip()

# Build snapshot
snapshot = {
    'zellij_session': zellij_session,
    'timestamp': timestamp,
    'pane_count': len(panes) if isinstance(panes, list) else 0,
    'pane_mappings': []
}

if isinstance(panes, list):
    for pane in panes:
        pane_id = str(pane.get('id', pane.get('pane_id', '')))
        entry = {
            'pane_id': pane_id,
            'tab_name': pane.get('tab_name', pane.get('tab', {}).get('name', '')),
            'tab_position': pane.get('tab_position', pane.get('tab', {}).get('position', -1)),
            'title': pane.get('title', ''),
            'command': pane.get('command', pane.get('running_command', '')),
            'cwd': pane.get('cwd', pane.get('current_working_directory', '')),
            'is_focused': pane.get('is_focused', pane.get('focused', False)),
        }
        # Cross-reference with map file
        if pane_id in pane_map:
            entry['opencode_session_id'] = pane_map[pane_id]
        snapshot['pane_mappings'].append(entry)

print(json.dumps(snapshot, indent=2))
" "$PANES_JSON" "$MAP_ENTRIES" "$ZELLIJ_SESSION" "$TIMESTAMP" > "$SNAPSHOT_JSON.tmp"

mv "$SNAPSHOT_JSON.tmp" "$SNAPSHOT_JSON"

# ── Output ──

if [[ "$QUIET" == false ]]; then
  PANE_COUNT=$(python3 -c "import json; d=json.load(open('$SNAPSHOT_JSON')); print(d.get('pane_count', 0))" 2>/dev/null || echo "?")
  MAPPED_COUNT=$(python3 -c "import json; d=json.load(open('$SNAPSHOT_JSON')); print(sum(1 for p in d.get('pane_mappings',[]) if 'opencode_session_id' in p))" 2>/dev/null || echo "?")
  echo "Snapshot saved for session '$ZELLIJ_SESSION' at $TIMESTAMP"
  echo "  Layout:   $SNAPSHOT_KDL"
  echo "  Metadata: $SNAPSHOT_JSON"
  echo "  Panes: $PANE_COUNT total, $MAPPED_COUNT with opencode bindings"
fi
