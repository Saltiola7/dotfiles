#!/bin/bash
#
# opencode-zellij v2 - Launch opencode with direct session binding to zellij panes
#
# Behavior:
#   1. Checks mapping file for a direct pane_id -> opencode_session_id binding
#   2. If bound, verifies the session still exists and resumes it
#   3. If unbound, finds the most recent unbound session for this directory
#   4. After opencode exits, writes the binding so next launch resumes the same session
#
# Usage:
#   opencode-zellij              # auto-detect context from zellij env vars
#   opencode-zellij --session X  # explicitly resume session X (passes through to opencode)
#
# Environment (set automatically by zellij):
#   ZELLIJ_SESSION_NAME - zellij session name (e.g., "tsc-dev")
#   ZELLIJ_PANE_ID      - numeric pane ID within the zellij session

set -euo pipefail

STORAGE_DIR="$HOME/.local/share/opencode-zellij"
mkdir -p "$STORAGE_DIR"

DB_PATH="${OPENCODE_DB:-$(opencode db path 2>/dev/null || echo "")}"
PROJECT_DIR="$(pwd)"

# Pass-through: if --session is explicitly provided, just forward to opencode
for arg in "$@"; do
  if [[ "$arg" == "--session" ]]; then
    exec opencode "$@"
  fi
done

# ── Helper: check if an opencode session exists and is not archived ──
session_exists() {
  local sid="$1"
  [[ -n "$DB_PATH" && -f "$DB_PATH" ]] || return 1
  local count
  count=$(sqlite3 "$DB_PATH" "
    SELECT COUNT(*) FROM session
    WHERE id = '$sid' AND time_archived IS NULL;
  " 2>/dev/null || echo "0")
  [[ "$count" -gt 0 ]]
}

# ── Helper: get all session IDs currently bound in a map file ──
bound_session_ids() {
  local map_file="$1"
  [[ -f "$map_file" ]] || return 0
  grep -v '^#' "$map_file" 2>/dev/null | grep -v '^$' | cut -d= -f2
}

# ── Helper: find the most recent unbound session for this directory ──
# If a seed file exists (from snapshot restore), prefer seeded sessions first.
find_unbound_session() {
  local map_file="$1"
  [[ -n "$DB_PATH" && -f "$DB_PATH" ]] || return 1

  # Get all bound session IDs as a comma-separated list for SQL NOT IN
  local bound_ids=""
  if [[ -f "$map_file" ]]; then
    bound_ids=$(bound_session_ids "$map_file" | sed "s/^/'/;s/$/'/" | paste -sd, -)
  fi

  local where_not_bound=""
  if [[ -n "$bound_ids" ]]; then
    where_not_bound="AND s.id NOT IN ($bound_ids)"
  fi

  # Check for seed file (created by workspace scripts from snapshot)
  local seed_file="$STORAGE_DIR/${ZELLIJ_SESSION:-standalone}.seed"
  if [[ -f "$seed_file" ]]; then
    # Try to find an unbound session from the seed list first
    local seed_ids
    seed_ids=$(grep -v '^$' "$seed_file" 2>/dev/null | sed "s/^/'/;s/$/'/" | paste -sd, - || true)
    if [[ -n "$seed_ids" ]]; then
      local seeded_session
      seeded_session=$(sqlite3 "$DB_PATH" "
        SELECT s.id
        FROM session s
        JOIN project p ON s.project_id = p.id
        WHERE p.worktree = '$PROJECT_DIR'
          AND s.time_archived IS NULL
          AND s.parent_id IS NULL
          AND s.id IN ($seed_ids)
          $where_not_bound
        ORDER BY s.time_updated DESC
        LIMIT 1;
      " 2>/dev/null || true)

      if [[ -n "$seeded_session" ]]; then
        # Remove this session from the seed file so next pane gets the next one
        local escaped_session
        escaped_session=$(printf '%s\n' "$seeded_session" | sed 's/[.[\*^$()+?{|\\]/\\&/g')
        grep -v "^${escaped_session}$" "$seed_file" > "$seed_file.tmp" 2>/dev/null || true
        mv "$seed_file.tmp" "$seed_file"
        echo "$seeded_session"
        return 0
      fi
    fi
  fi

  # Fallback: most recent unbound session
  sqlite3 "$DB_PATH" "
    SELECT s.id
    FROM session s
    JOIN project p ON s.project_id = p.id
    WHERE p.worktree = '$PROJECT_DIR'
      AND s.time_archived IS NULL
      AND s.parent_id IS NULL
      $where_not_bound
    ORDER BY s.time_updated DESC
    LIMIT 1;
  " 2>/dev/null || true
}

# ── Helper: find the most recently used session after opencode exits ──
find_latest_session() {
  [[ -n "$DB_PATH" && -f "$DB_PATH" ]] || return 1
  sqlite3 "$DB_PATH" "
    SELECT s.id
    FROM session s
    JOIN project p ON s.project_id = p.id
    WHERE p.worktree = '$PROJECT_DIR'
      AND s.time_archived IS NULL
      AND s.parent_id IS NULL
    ORDER BY s.time_updated DESC
    LIMIT 1;
  " 2>/dev/null || true
}

# ── Main logic ──

ZELLIJ_SESSION="${ZELLIJ_SESSION_NAME:-}"
ZELLIJ_PANE="${ZELLIJ_PANE_ID:-}"
MAP_FILE="$STORAGE_DIR/${ZELLIJ_SESSION:-standalone}.map"
SESSION_ID=""

if [[ -n "$ZELLIJ_SESSION" && -n "$ZELLIJ_PANE" ]]; then
  # Running inside zellij - try direct binding lookup
  if [[ -f "$MAP_FILE" ]]; then
    EXISTING=$(grep "^${ZELLIJ_PANE}=" "$MAP_FILE" 2>/dev/null || true)
    if [[ -n "$EXISTING" ]]; then
      SESSION_ID="${EXISTING#*=}"
      # Verify the session still exists
      if ! session_exists "$SESSION_ID"; then
        echo "Bound session $SESSION_ID no longer exists. Finding a new one..."
        # Remove stale binding
        grep -v "^${ZELLIJ_PANE}=" "$MAP_FILE" > "$MAP_FILE.tmp" 2>/dev/null || true
        mv "$MAP_FILE.tmp" "$MAP_FILE"
        SESSION_ID=""
      fi
    fi
  fi

  # No valid binding - find an unbound session
  if [[ -z "$SESSION_ID" ]]; then
    SESSION_ID=$(find_unbound_session "$MAP_FILE")
    if [[ -n "$SESSION_ID" ]]; then
      # Write the new binding
      echo "${ZELLIJ_PANE}=${SESSION_ID}" >> "$MAP_FILE"
      echo "Bound pane $ZELLIJ_PANE to session $SESSION_ID"
    fi
  fi
else
  # Not in zellij - just find the most recent session
  SESSION_ID=$(find_latest_session)
fi

# ── Launch opencode ──

if [[ -n "$SESSION_ID" ]]; then
  echo "Resuming opencode session: $SESSION_ID"
  opencode --session "$SESSION_ID"
  EXIT_CODE=$?
else
  echo "No previous session found for $PROJECT_DIR. Starting fresh."
  opencode
  EXIT_CODE=$?
fi

# ── Post-exec: capture binding for fresh sessions ──

if [[ -n "$ZELLIJ_SESSION" && -n "$ZELLIJ_PANE" ]]; then
  # Check if this pane now has a binding (it might if we resumed)
  CURRENT_BINDING=$(grep "^${ZELLIJ_PANE}=" "$MAP_FILE" 2>/dev/null || true)
  if [[ -z "$CURRENT_BINDING" ]]; then
    # opencode ran fresh - find what session it created and bind it
    NEW_SESSION_ID=$(find_latest_session)
    if [[ -n "$NEW_SESSION_ID" ]]; then
      echo "${ZELLIJ_PANE}=${NEW_SESSION_ID}" >> "$MAP_FILE"
      echo "Post-exec: bound pane $ZELLIJ_PANE to new session $NEW_SESSION_ID"
    fi
  fi
fi

exit ${EXIT_CODE:-0}
