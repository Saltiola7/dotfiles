#!/bin/bash
#
# opencode-kitty - Launch opencode with session binding to Kitty window IDs
#
# Behavior:
#   1. Purges stale window->session bindings (windows no longer in kitty)
#   2. Checks mapping file for a direct kitty_window_id -> opencode_session_id binding
#   3. If bound, verifies the session still exists and resumes it
#   4. If unbound, finds the most recent unbound session for this directory
#
# Usage:
#   opencode-kitty              # auto-detect context from KITTY_WINDOW_ID
#   opencode-kitty --session X  # explicitly resume session X (passes through to opencode)
#   opencode-kitty --validate   # check prerequisites without executing
#
# Debugging:
#   KITTY_WORKSPACE_DEBUG=1 opencode-kitty
#   tail -f ~/.local/share/kitty/workspace.log
#
# Environment (set automatically by Kitty):
#   KITTY_WINDOW_ID - numeric window ID within the Kitty instance
#
# Dependencies:
#   - kitty-query.py (installed via chezmoi to ~/.config/kitty/kitty-query.py)
#   - uv (for running kitty-query.py with inline dependencies)

set -uo pipefail
trap 'echo "opencode-kitty: error on line $LINENO" >&2' ERR

# ── Shared tooling ──

KQ="$HOME/.config/kitty/kitty-query.py"
OC_STORAGE="$HOME/.local/share/opencode-kitty"
LOG_FILE="$HOME/.local/share/kitty/workspace.log"
SOCKET_GLOB="$HOME/.local/share/kitty/control-socket-*"

mkdir -p "$OC_STORAGE"

DB_PATH="${OPENCODE_DB:-$(opencode db path 2>/dev/null || echo "")}"
PROJECT_DIR="$(pwd)"

log() {
    [[ "${KITTY_WORKSPACE_DEBUG:-}" == "1" ]] || return 0
    echo "[$(date '+%H:%M:%S')] opencode-kitty: $*" >> "$LOG_FILE"
}

_find_socket() { ls $SOCKET_GLOB 2>/dev/null | head -1 || true; }

# ── Validate mode ──

if [[ "${1:-}" == "--validate" ]]; then
    echo "opencode-kitty prerequisites:"

    # kitty binary
    _kitty=$(command -v kitty || true)
    if [[ -n "$_kitty" ]]; then
        echo "  [OK] kitty binary: $_kitty"
    else
        echo "  [FAIL] kitty binary: not found on PATH"
    fi

    # uv
    _uv=$(command -v uv || true)
    if [[ -n "$_uv" ]]; then
        echo "  [OK] uv: $_uv"
    else
        echo "  [FAIL] uv: not found on PATH"
    fi

    # kitty-query.py
    if [[ -f "$KQ" ]]; then
        echo "  [OK] kitty-query: $KQ"
    else
        echo "  [FAIL] kitty-query: $KQ (not found)"
    fi

    # kitty socket
    _socket=$(_find_socket)
    if [[ -n "$_socket" ]]; then
        echo "  [OK] kitty socket: $_socket"
    else
        echo "  [WARN] kitty socket: not found (kitty not running)"
    fi

    # opencode binary
    _oc=$(command -v opencode || true)
    if [[ -n "$_oc" ]]; then
        echo "  [OK] opencode: $_oc"
    else
        echo "  [FAIL] opencode: not found on PATH"
    fi

    # opencode DB
    if [[ -n "$DB_PATH" && -f "$DB_PATH" ]]; then
        echo "  [OK] opencode DB: $DB_PATH"
    elif [[ -n "$DB_PATH" ]]; then
        echo "  [FAIL] opencode DB: $DB_PATH (file not found)"
    else
        echo "  [FAIL] opencode DB: path unknown"
    fi

    # sqlite3
    _sql=$(command -v sqlite3 || true)
    if [[ -n "$_sql" ]]; then
        echo "  [OK] sqlite3: $_sql"
    else
        echo "  [FAIL] sqlite3: not found on PATH"
    fi

    # python3
    _py=$(command -v python3 || true)
    if [[ -n "$_py" ]]; then
        echo "  [OK] python3: $_py"
    else
        echo "  [FAIL] python3: not found on PATH"
    fi

    # KITTY_WINDOW_ID
    if [[ -n "${KITTY_WINDOW_ID:-}" ]]; then
        echo "  [OK] KITTY_WINDOW_ID: $KITTY_WINDOW_ID"
    else
        echo "  [WARN] KITTY_WINDOW_ID: not set (not running inside kitty)"
    fi

    # workspace detection
    if [[ -n "${_socket:-}" && -n "${_kitty:-}" && -n "${KITTY_WINDOW_ID:-}" ]]; then
        _ws=$("$_kitty" @ --to=unix:"$_socket" ls 2>/dev/null \
            | uv run --script "$KQ" detect-workspace "$KITTY_WINDOW_ID" 2>/dev/null || true)
        if [[ -n "$_ws" ]]; then
            echo "  [OK] workspace: $_ws"
        else
            echo "  [WARN] workspace: not detected for window $KITTY_WINDOW_ID"
        fi
    else
        echo "  [SKIP] workspace: cannot detect (missing socket/kitty/window ID)"
    fi

    # map file
    _ws="${_ws:-standalone}"
    _map="$OC_STORAGE/${_ws}.map"
    if [[ -f "$_map" ]]; then
        _total=$(grep -c '=' "$_map" 2>/dev/null || echo 0)
        _stale=0
        if [[ -n "${_socket:-}" && -n "${_kitty:-}" ]]; then
            _live=$("$_kitty" @ --to=unix:"$_socket" ls 2>/dev/null \
                | uv run --script "$KQ" list-win-ids 2>/dev/null || true)
            while IFS='=' read -r wid sid; do
                [[ -z "$wid" || "$wid" == \#* ]] && continue
                if ! echo "$_live" | grep -qx "$wid" 2>/dev/null; then
                    _stale=$((_stale + 1))
                fi
            done < "$_map"
        fi
        echo "  [OK] map file: $_map ($_total bindings, $_stale stale)"
    else
        echo "  [INFO] map file: $_map (does not exist yet)"
    fi

    # sessions for this project
    if [[ -n "$DB_PATH" && -f "$DB_PATH" ]]; then
        _total_sessions=$(uv run --script "$KQ" query-sessions-cmd "$DB_PATH" "$PROJECT_DIR" --limit 100 2>/dev/null | wc -l | tr -d ' ')
        echo "  [OK] sessions for $PROJECT_DIR: $_total_sessions active"
    fi

    # secret function
    if bash -l -c 'type secret' &>/dev/null; then
        echo "  [OK] secret(): available in login shell"
    else
        echo "  [WARN] secret(): not found in login shell"
    fi

    exit 0
fi

# ── Pass-through: if --session is explicitly provided, just forward to opencode ──

for arg in "$@"; do
    if [[ "$arg" == "--session" ]]; then
        exec opencode "$@"
    fi
done

log "Starting: KITTY_WINDOW_ID=${KITTY_WINDOW_ID:-unset} project=$PROJECT_DIR"

# ── Detect workspace name from Kitty user vars ──

detect_workspace() {
    local socket
    socket=$(_find_socket)
    [[ -n "$socket" ]] || return 1

    "$(command -v kitty)" @ --to=unix:"$socket" ls 2>/dev/null \
        | uv run --script "$KQ" detect-workspace "${KITTY_WINDOW_ID:-0}" 2>/dev/null || true
}

# ── Main logic ──

KITTY_WIN="${KITTY_WINDOW_ID:-}"
WORKSPACE=$(detect_workspace)
MAP_FILE="$OC_STORAGE/${WORKSPACE:-standalone}.map"
SESSION_ID=""

log "Workspace: ${WORKSPACE:-none}, map: $MAP_FILE"

if [[ -z "$DB_PATH" || ! -f "$DB_PATH" ]]; then
    log "WARNING: opencode DB not found at '$DB_PATH'"
fi

# Purge stale bindings via kitty-query
if [[ -n "$WORKSPACE" && -f "$MAP_FILE" ]]; then
    LIVE_WIN_IDS=$(
        socket=$(_find_socket)
        if [[ -n "$socket" ]]; then
            "$(command -v kitty)" @ --to=unix:"$socket" ls 2>/dev/null \
                | uv run --script "$KQ" list-win-ids 2>/dev/null || true
        fi
    )

    if [[ -n "$LIVE_WIN_IDS" ]]; then
        # shellcheck disable=SC2086
        uv run --script "$KQ" purge-stale "$MAP_FILE" $LIVE_WIN_IDS 2>/dev/null || true
    fi
fi

if [[ -n "$KITTY_WIN" && -n "$WORKSPACE" ]]; then
    # Running inside a workspace -- try direct binding lookup
    if [[ -f "$MAP_FILE" ]]; then
        EXISTING=$(grep "^${KITTY_WIN}=" "$MAP_FILE" 2>/dev/null || true)
        if [[ -n "$EXISTING" ]]; then
            SESSION_ID="${EXISTING#*=}"
            log "Direct binding found: window $KITTY_WIN -> session $SESSION_ID"
            if ! uv run --script "$KQ" session-exists-cmd "$DB_PATH" "$SESSION_ID" &>/dev/null; then
                log "Bound session $SESSION_ID no longer exists, removing"
                grep -v "^${KITTY_WIN}=" "$MAP_FILE" > "$MAP_FILE.tmp" 2>/dev/null || true
                mv "$MAP_FILE.tmp" "$MAP_FILE"
                SESSION_ID=""
            fi
        fi
    fi

    # No valid binding -- find an unbound session
    if [[ -z "$SESSION_ID" ]]; then
        log "No direct binding, searching for unbound session..."
        SESSION_ID=$(uv run --script "$KQ" find-unbound-session \
            "$DB_PATH" "$PROJECT_DIR" "$MAP_FILE" "$WORKSPACE" 2>/dev/null || true)
        if [[ -n "$SESSION_ID" ]]; then
            echo "${KITTY_WIN}=${SESSION_ID}" >> "$MAP_FILE"
            log "Bound window $KITTY_WIN to session $SESSION_ID"
        fi
    fi
else
    # Not in a workspace -- just find the most recent session
    log "No workspace context, finding latest session"
    SESSION_ID=$(uv run --script "$KQ" query-sessions-cmd \
        "$DB_PATH" "$PROJECT_DIR" 2>/dev/null || true)
fi

# ── Launch opencode ──

if [[ -n "$SESSION_ID" ]]; then
    log "Resuming session: $SESSION_ID"
    echo "Resuming opencode session: $SESSION_ID"
    opencode --session "$SESSION_ID"
    EXIT_CODE=$?
else
    log "No session found, starting fresh"
    echo "No previous session found for $PROJECT_DIR. Starting fresh."
    opencode
    EXIT_CODE=$?
fi

# If opencode exits, keep the pane alive so errors are visible
if [[ $EXIT_CODE -ne 0 ]]; then
    log "opencode exited with code $EXIT_CODE"
    echo ""
    echo "opencode exited with code $EXIT_CODE. Press Enter to close, or type a command."
    exec bash
else
    log "opencode exited cleanly"
fi
