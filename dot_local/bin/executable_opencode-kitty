#!/bin/bash
#
# opencode-kitty - Launch opencode with session binding to Kitty window IDs
#
# Behavior:
#   1. Purges stale window->session bindings (windows no longer in kitty)
#   2. Checks mapping file for a direct kitty_window_id -> opencode_session_id binding
#   3. If bound, verifies the session still exists and resumes it
#   4. If unbound, finds the most recent unbound session for this directory
#
# Usage:
#   opencode-kitty              # auto-detect context from KITTY_WINDOW_ID
#   opencode-kitty --session X  # explicitly resume session X (passes through to opencode)
#   opencode-kitty --validate   # check prerequisites without executing
#
# Debugging:
#   KITTY_WORKSPACE_DEBUG=1 opencode-kitty
#   tail -f ~/.local/share/kitty/workspace.log
#
# Environment (set automatically by Kitty):
#   KITTY_WINDOW_ID - numeric window ID within the Kitty instance

set -uo pipefail
trap 'echo "opencode-kitty: error on line $LINENO" >&2' ERR

# ── Logging ──

LOG_FILE="$HOME/.local/share/kitty/workspace.log"

log() {
    if [[ "${KITTY_WORKSPACE_DEBUG:-}" == "1" ]]; then
        echo "[$(date '+%H:%M:%S')] opencode-kitty: $*" >> "$LOG_FILE"
    fi
}

# ── Constants ──

OC_STORAGE="$HOME/.local/share/opencode-kitty"
SOCKET_GLOB="$HOME/.local/share/kitty/control-socket-*"

mkdir -p "$OC_STORAGE"

DB_PATH="${OPENCODE_DB:-$(opencode db path 2>/dev/null || echo "")}"
PROJECT_DIR="$(pwd)"

# ── Validate mode ──

if [[ "${1:-}" == "--validate" ]]; then
    echo "opencode-kitty prerequisites:"

    # kitty binary
    _kitty=$(command -v kitty || true)
    if [[ -n "$_kitty" ]]; then
        echo "  [OK] kitty binary: $_kitty"
    else
        echo "  [FAIL] kitty binary: not found on PATH"
    fi

    # kitty socket
    _socket=$(ls $SOCKET_GLOB 2>/dev/null | head -1 || true)
    if [[ -n "$_socket" ]]; then
        echo "  [OK] kitty socket: $_socket"
    else
        echo "  [WARN] kitty socket: not found (kitty not running)"
    fi

    # opencode binary
    _oc=$(command -v opencode || true)
    if [[ -n "$_oc" ]]; then
        echo "  [OK] opencode: $_oc"
    else
        echo "  [FAIL] opencode: not found on PATH"
    fi

    # opencode DB
    if [[ -n "$DB_PATH" && -f "$DB_PATH" ]]; then
        echo "  [OK] opencode DB: $DB_PATH"
    elif [[ -n "$DB_PATH" ]]; then
        echo "  [FAIL] opencode DB: $DB_PATH (file not found)"
    else
        echo "  [FAIL] opencode DB: path unknown"
    fi

    # sqlite3
    _sql=$(command -v sqlite3 || true)
    if [[ -n "$_sql" ]]; then
        echo "  [OK] sqlite3: $_sql"
    else
        echo "  [FAIL] sqlite3: not found on PATH"
    fi

    # python3
    _py=$(command -v python3 || true)
    if [[ -n "$_py" ]]; then
        echo "  [OK] python3: $_py"
    else
        echo "  [FAIL] python3: not found on PATH"
    fi

    # KITTY_WINDOW_ID
    if [[ -n "${KITTY_WINDOW_ID:-}" ]]; then
        echo "  [OK] KITTY_WINDOW_ID: $KITTY_WINDOW_ID"
    else
        echo "  [WARN] KITTY_WINDOW_ID: not set (not running inside kitty)"
    fi

    # workspace detection
    if [[ -n "$_socket" && -n "$_kitty" && -n "${KITTY_WINDOW_ID:-}" ]]; then
        _ws=$("$_kitty" @ --to=unix:"$_socket" ls 2>/dev/null | python3 -c "
import json, sys
win_id = int(sys.argv[1])
data = json.load(sys.stdin)
for oswin in data:
    for tab in oswin.get('tabs', []):
        for win in tab.get('windows', []):
            if win['id'] == win_id:
                for t2 in oswin.get('tabs', []):
                    for w2 in t2.get('windows', []):
                        ws = w2.get('user_vars', {}).get('workspace')
                        if ws:
                            print(ws)
                            sys.exit(0)
" "$KITTY_WINDOW_ID" 2>/dev/null || true)
        if [[ -n "$_ws" ]]; then
            echo "  [OK] workspace: $_ws"
        else
            echo "  [WARN] workspace: not detected for window $KITTY_WINDOW_ID"
        fi
    else
        echo "  [SKIP] workspace: cannot detect (missing socket/kitty/window ID)"
    fi

    # map file
    _ws="${_ws:-standalone}"
    _map="$OC_STORAGE/${_ws}.map"
    if [[ -f "$_map" ]]; then
        _total=$(grep -c '=' "$_map" 2>/dev/null || echo 0)
        _stale=0
        if [[ -n "$_socket" && -n "$_kitty" ]]; then
            _live=$("$_kitty" @ --to=unix:"$_socket" ls 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
for oswin in data:
    for tab in oswin.get('tabs', []):
        for win in tab.get('windows', []):
            print(win['id'])
" 2>/dev/null || true)
            while IFS='=' read -r wid sid; do
                [[ -z "$wid" || "$wid" == \#* ]] && continue
                if ! echo "$_live" | grep -qx "$wid" 2>/dev/null; then
                    _stale=$((_stale + 1))
                fi
            done < "$_map"
        fi
        echo "  [OK] map file: $_map ($_total bindings, $_stale stale)"
    else
        echo "  [INFO] map file: $_map (does not exist yet)"
    fi

    # sessions for this project
    if [[ -n "$DB_PATH" && -f "$DB_PATH" ]]; then
        _total_sessions=$(sqlite3 "$DB_PATH" "
            SELECT COUNT(*) FROM session s
            JOIN project p ON s.project_id = p.id
            WHERE p.worktree = '$PROJECT_DIR'
              AND s.time_archived IS NULL
              AND s.parent_id IS NULL;
        " 2>/dev/null || echo 0)
        echo "  [OK] sessions for $PROJECT_DIR: $_total_sessions active"
    fi

    # secret function
    if bash -l -c 'type secret' &>/dev/null; then
        echo "  [OK] secret(): available in login shell"
    else
        echo "  [WARN] secret(): not found in login shell"
    fi

    exit 0
fi

# ── Pass-through: if --session is explicitly provided, just forward to opencode ──

for arg in "$@"; do
    if [[ "$arg" == "--session" ]]; then
        exec opencode "$@"
    fi
done

log "Starting: KITTY_WINDOW_ID=${KITTY_WINDOW_ID:-unset} project=$PROJECT_DIR"

# ── Detect workspace name from Kitty user vars ──

detect_workspace() {
    local socket
    socket=$(ls $SOCKET_GLOB 2>/dev/null | head -1 || true)
    [[ -n "$socket" ]] || return 1

    "$(command -v kitty)" @ --to=unix:"$socket" ls 2>/dev/null | python3 -c "
import json, sys
win_id = int(sys.argv[1])
data = json.load(sys.stdin)
for oswin in data:
    for tab in oswin.get('tabs', []):
        for win in tab.get('windows', []):
            if win.get('user_vars', {}).get('workspace'):
                # Found workspace tag -- return it for any window in this OS window
                # Check if our window is in this OS window
                pass
        for win in tab.get('windows', []):
            if win['id'] == win_id:
                # Found our window -- now find the workspace tag in this OS window
                for t2 in oswin.get('tabs', []):
                    for w2 in t2.get('windows', []):
                        ws = w2.get('user_vars', {}).get('workspace')
                        if ws:
                            print(ws)
                            sys.exit(0)
" "${KITTY_WINDOW_ID:-0}" 2>/dev/null || true
}

# ── Helpers ──

session_exists() {
    local sid="$1"
    [[ -n "$DB_PATH" && -f "$DB_PATH" ]] || return 1
    local count
    count=$(sqlite3 "$DB_PATH" "
        SELECT COUNT(*) FROM session
        WHERE id = '$sid' AND time_archived IS NULL;
    " 2>/dev/null || echo "0")
    [[ "$count" -gt 0 ]]
}

bound_session_ids() {
    local map_file="$1"
    [[ -f "$map_file" ]] || return 0
    grep -v '^#' "$map_file" 2>/dev/null | grep -v '^$' | cut -d= -f2
}

find_unbound_session() {
    local map_file="$1"
    [[ -n "$DB_PATH" && -f "$DB_PATH" ]] || return 0

    local bound_ids=""
    if [[ -f "$map_file" ]]; then
        bound_ids=$(bound_session_ids "$map_file" | sed "s/^/'/;s/$/'/" | paste -sd, -)
    fi

    local where_not_bound=""
    if [[ -n "$bound_ids" ]]; then
        where_not_bound="AND s.id NOT IN ($bound_ids)"
    fi

    # Check for seed file (created by kitty-workspace from snapshot restore)
    local seed_file="$OC_STORAGE/${WORKSPACE:-standalone}.seed"
    if [[ -f "$seed_file" ]]; then
        local seed_ids
        seed_ids=$(grep -v '^$' "$seed_file" 2>/dev/null | sed "s/^/'/;s/$/'/" | paste -sd, - || true)
        if [[ -n "$seed_ids" ]]; then
            local seeded_session
            seeded_session=$(sqlite3 "$DB_PATH" "
                SELECT s.id
                FROM session s
                JOIN project p ON s.project_id = p.id
                WHERE p.worktree = '$PROJECT_DIR'
                  AND s.time_archived IS NULL
                  AND s.parent_id IS NULL
                  AND s.id IN ($seed_ids)
                  $where_not_bound
                ORDER BY s.time_updated DESC
                LIMIT 1;
            " 2>/dev/null || true)

            if [[ -n "$seeded_session" ]]; then
                # Remove from seed so next pane gets the next one
                local escaped
                escaped=$(printf '%s\n' "$seeded_session" | sed 's/[.[\*^$()+?{|\\]/\\&/g')
                grep -v "^${escaped}$" "$seed_file" > "$seed_file.tmp" 2>/dev/null || true
                mv "$seed_file.tmp" "$seed_file"
                log "Found seeded session: $seeded_session"
                echo "$seeded_session"
                return 0
            fi
        fi
    fi

    # Fallback: most recent unbound session
    local result
    result=$(sqlite3 "$DB_PATH" "
        SELECT s.id
        FROM session s
        JOIN project p ON s.project_id = p.id
        WHERE p.worktree = '$PROJECT_DIR'
          AND s.time_archived IS NULL
          AND s.parent_id IS NULL
          $where_not_bound
        ORDER BY s.time_updated DESC
        LIMIT 1;
    " 2>/dev/null || true)
    if [[ -n "$result" ]]; then
        log "Found unbound session: $result"
    fi
    echo "$result"
}

find_latest_session() {
    [[ -n "$DB_PATH" && -f "$DB_PATH" ]] || return 0
    sqlite3 "$DB_PATH" "
        SELECT s.id
        FROM session s
        JOIN project p ON s.project_id = p.id
        WHERE p.worktree = '$PROJECT_DIR'
          AND s.time_archived IS NULL
          AND s.parent_id IS NULL
        ORDER BY s.time_updated DESC
        LIMIT 1;
    " 2>/dev/null || true
}

# ── Get live kitty window IDs ──

get_live_window_ids() {
    local socket
    socket=$(ls $SOCKET_GLOB 2>/dev/null | head -1 || true)
    [[ -n "$socket" ]] || return 0
    "$(command -v kitty)" @ --to=unix:"$socket" ls 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
for oswin in data:
    for tab in oswin.get('tabs', []):
        for win in tab.get('windows', []):
            print(win['id'])
" 2>/dev/null || true
}

# ── Main logic ──

KITTY_WIN="${KITTY_WINDOW_ID:-}"
WORKSPACE=$(detect_workspace)
MAP_FILE="$OC_STORAGE/${WORKSPACE:-standalone}.map"
SESSION_ID=""

log "Workspace: ${WORKSPACE:-none}, map: $MAP_FILE"

if [[ -z "$DB_PATH" || ! -f "$DB_PATH" ]]; then
    log "WARNING: opencode DB not found at '$DB_PATH'"
fi

# Purge stale bindings: remove map entries whose kitty window ID no longer exists
if [[ -n "$WORKSPACE" && -f "$MAP_FILE" ]]; then
    LIVE_WIN_IDS=$(get_live_window_ids)

    if [[ -n "$LIVE_WIN_IDS" ]]; then
        CLEANED=false
        while IFS='=' read -r wid sid; do
            [[ -z "$wid" || "$wid" == \#* ]] && continue
            if ! echo "$LIVE_WIN_IDS" | grep -qx "$wid"; then
                log "Purging stale binding: window $wid -> $sid"
                CLEANED=true
            fi
        done < "$MAP_FILE"

        if $CLEANED; then
            > "$MAP_FILE.tmp"
            while IFS='=' read -r wid sid; do
                [[ -z "$wid" || "$wid" == \#* ]] && continue
                if echo "$LIVE_WIN_IDS" | grep -qx "$wid"; then
                    echo "${wid}=${sid}" >> "$MAP_FILE.tmp"
                fi
            done < "$MAP_FILE"
            mv "$MAP_FILE.tmp" "$MAP_FILE"
            log "Map cleaned, remaining bindings: $(wc -l < "$MAP_FILE" | tr -d ' ')"
        fi
    fi
fi

if [[ -n "$KITTY_WIN" && -n "$WORKSPACE" ]]; then
    # Running inside a workspace -- try direct binding lookup
    if [[ -f "$MAP_FILE" ]]; then
        EXISTING=$(grep "^${KITTY_WIN}=" "$MAP_FILE" 2>/dev/null || true)
        if [[ -n "$EXISTING" ]]; then
            SESSION_ID="${EXISTING#*=}"
            log "Direct binding found: window $KITTY_WIN -> session $SESSION_ID"
            if ! session_exists "$SESSION_ID"; then
                log "Bound session $SESSION_ID no longer exists, removing"
                grep -v "^${KITTY_WIN}=" "$MAP_FILE" > "$MAP_FILE.tmp" 2>/dev/null || true
                mv "$MAP_FILE.tmp" "$MAP_FILE"
                SESSION_ID=""
            fi
        fi
    fi

    # No valid binding -- find an unbound session
    if [[ -z "$SESSION_ID" ]]; then
        log "No direct binding, searching for unbound session..."
        SESSION_ID=$(find_unbound_session "$MAP_FILE")
        if [[ -n "$SESSION_ID" ]]; then
            echo "${KITTY_WIN}=${SESSION_ID}" >> "$MAP_FILE"
            log "Bound window $KITTY_WIN to session $SESSION_ID"
        fi
    fi
else
    # Not in a workspace -- just find the most recent session
    log "No workspace context, finding latest session"
    SESSION_ID=$(find_latest_session)
fi

# ── Launch opencode ──

if [[ -n "$SESSION_ID" ]]; then
    log "Resuming session: $SESSION_ID"
    echo "Resuming opencode session: $SESSION_ID"
    exec opencode --session "$SESSION_ID"
else
    log "No session found, starting fresh"
    echo "No previous session found for $PROJECT_DIR. Starting fresh."
    exec opencode
fi
