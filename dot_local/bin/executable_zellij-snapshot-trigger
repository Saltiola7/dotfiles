#!/bin/bash
#
# zellij-snapshot-trigger - Triggers a snapshot in a floating pane
#
# This is meant to be called from within a zellij session.
# It opens a small floating pane that runs zellij-snapshot and auto-closes.
#
# Usage:
#   zellij-snapshot-trigger     # called from a keybinding helper or alias

zellij run --floating --close-on-exit --name "snapshot" -- zellij-snapshot
