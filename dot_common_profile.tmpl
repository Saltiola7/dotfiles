# Common Shell Configuration (Bash & Zsh)
# Shared PATH, environment variables, and aliases for both shells and all machines

# --- PATH Setup ---

# Homebrew (must be early for brew commands to work)
export PATH="/opt/homebrew/bin:$PATH"

# Local bin
export PATH="{{ .chezmoi.homeDir }}/.local/bin:$PATH"

# Cargo / Rust
export PATH="{{ .chezmoi.homeDir }}/.cargo/bin:$PATH"

# .NET tools
export PATH="{{ .chezmoi.homeDir }}/.dotnet/tools:$PATH"

# Volta (Node version manager)
export VOLTA_HOME="{{ .chezmoi.homeDir }}/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"

# NPM global
if [ -z "$INTELLIJ_ENVIRONMENT_READER" ]; then
    if command -v npm &> /dev/null; then
        export PATH="$(npm config get prefix)/bin:$PATH"
    fi
fi

# Ruby
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
export PATH="/opt/homebrew/lib/ruby/gems/4.0.0/bin:$PATH"

# Homebrew PHP
export PATH="/opt/homebrew/opt/php@8.2/bin:$PATH"
export PATH="/opt/homebrew/opt/php@8.2/sbin:$PATH"

# Homebrew Postgres
export PATH="/opt/homebrew/opt/postgresql@16/bin:$PATH"
export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"

# LM Studio CLI
export PATH="$PATH:{{ .chezmoi.homeDir }}/.cache/lm-studio/bin"

# Antigravity
export PATH="{{ .chezmoi.homeDir }}/.antigravity/antigravity/bin:$PATH"

# Abctl
export PATH="$PATH:{{ .chezmoi.homeDir }}/abctl"

# JetBrains Toolbox
export PATH="$PATH:{{ .chezmoi.homeDir }}/Library/Application Support/JetBrains/Toolbox/scripts"

# Modular / Mojo
export MODULAR_HOME="{{ .chezmoi.homeDir }}/.modular"
export PATH="{{ .chezmoi.homeDir }}/.modular/pkg/packages.modular.com_mojo/bin:$PATH"

# Google Cloud SDK (shell-aware: zsh needs .zsh.inc, bash needs .bash.inc)
if [ -n "$ZSH_VERSION" ]; then
    [ -f "{{ .chezmoi.homeDir }}/google-cloud-sdk/path.zsh.inc" ] && . "{{ .chezmoi.homeDir }}/google-cloud-sdk/path.zsh.inc"
else
    [ -f "{{ .chezmoi.homeDir }}/google-cloud-sdk/path.bash.inc" ] && . "{{ .chezmoi.homeDir }}/google-cloud-sdk/path.bash.inc"
fi
export USE_GKE_GCLOUD_AUTH_PLUGIN=True

# KeePassXC
export PATH="$PATH:/Applications/KeePassXC.app/Contents/MacOS/"

# Pkg Config
export PKG_CONFIG_PATH="/opt/homebrew/opt/openblas/lib/pkgconfig:$PKG_CONFIG_PATH"

# --- Aliases ---
alias vim='nvim'
alias python='python3'
alias py='python3'

# Screaming Frog
alias sf='/Applications/Screaming\ Frog\ SEO\ Spider.app/Contents/MacOS/ScreamingFrogSEOSpiderLauncher'
export PATH="$PATH:/Applications/Screaming Frog SEO Spider.app/Contents/MacOS/"


# ClickHouse
alias ch="clickhouse client --host \"\$(op read 'op://Personal/ClickHouse Cloud/host')\" --secure --password"

# --- Environment Variables ---

# Carapace completion bridges
export CARAPACE_BRIDGES="zsh,fish,bash,inshellisense"

# --- Secrets (lazy-loaded via 1Password CLI) ---
# Run 'secret' to load all secrets into the current shell session.
# Secrets are cached in memory — only one biometric prompt per session.
secret() {
  if [ -n "$_SECRETS_LOADED" ]; then
    echo "Secrets already loaded."
    return 0
  fi
  echo "Loading secrets from 1Password..."
  export GEMINI_API_KEY="$(op read 'op://Personal/Gemini API Key/credential')" && \
  export GEMINI_DEEP_RESEARCH_API_KEY="$GEMINI_API_KEY" && \
  export GOOGLE_GENERATIVE_AI_API_KEY="$(op read 'op://Personal/Google AI API Key/credential')" && \
  export OPENAI_API_KEY="$(op read 'op://Personal/OpenAI API Key/credential')" && \
  export AWS_PROFILE="$(op read 'op://Personal/AWS Bedrock/profile')" && \
  export AWS_REGION="$(op read 'op://Personal/AWS Bedrock/region')" && \
  export CLAUDE_CODE_USE_BEDROCK=1 && \
  # --- GCP Service Account ---
  mkdir -p "$HOME/.cache/gcp" && \
  op read 'op://Personal/GCP Service Account - Enterprise SEO Tools/credential' > "$HOME/.cache/gcp/enterprise-seo-tools-sa.json" && \
  chmod 600 "$HOME/.cache/gcp/enterprise-seo-tools-sa.json" && \
  export GOOGLE_APPLICATION_CREDENTIALS="$HOME/.cache/gcp/enterprise-seo-tools-sa.json" && \
  export GOOGLE_VERTEX_PROJECT="$(op read 'op://Personal/GCP Service Account - Enterprise SEO Tools/project')" && \
  export GOOGLE_VERTEX_LOCATION="$(op read 'op://Personal/GCP Service Account - Enterprise SEO Tools/location')" && \
  export GOOGLE_CLOUD_PROJECT="$GOOGLE_VERTEX_PROJECT" && \
  # --- SEO Data Science (MGM) ---
  export CLICKHOUSE_HOST="$(op read 'op://Personal/ClickHouse MGM Cloud/host')" && \
  export CLICKHOUSE_USER="$(op read 'op://Personal/ClickHouse MGM Cloud/user')" && \
  export CLICKHOUSE_PORT="$(op read 'op://Personal/ClickHouse MGM Cloud/port')" && \
  export CLICKHOUSE_PASSWORD="$(op read 'op://Personal/ClickHouse MGM Cloud/password')" && \
  export SEMRUSH_API="$(op read 'op://Personal/SEMRUSH API/credential')" && \
  export SEMRUSH_ENTERPRISE_API="$(op read 'op://Personal/SEMRUSH API/enterprise')" && \
  export PAGESPEED_API_KEY="$(op read 'op://Personal/PageSpeed API/credential')" && \
  export AI_STUDIO_KEY="$GOOGLE_GENERATIVE_AI_API_KEY" && \
  export GCS_AKAMAI_ACCESS_KEY="$(op read 'op://Personal/Akamai GCS HMAC/access_key')" && \
  export GCS_AKAMAI_SECRET_KEY="$(op read 'op://Personal/Akamai GCS HMAC/secret_key')" && \
  export GITHUB_PERSONAL_ACCESS_TOKEN_CLASSIC="$(op read 'op://Personal/GitHub PAT Classic/credential')" && \
  export ATLASSIAN_API="$(op read 'op://Personal/Atlassian API Token/credential')" && \
  export ROVODEV="$ATLASSIAN_API" && \
  export EMAIL="$(op read 'op://Personal/Atlassian API Token/email')" && \
  export ATLASSIAN_URL="$(op read 'op://Personal/Atlassian API Token/url')" && \
  # --- GWS Content Reader SA (materialized for file-path consumers) ---
  op read 'op://Personal/GCP Service Account - GWS Content Reader/credential' > "$HOME/.cache/gcp/gws-content-reader-key.json" && \
  chmod 600 "$HOME/.cache/gcp/gws-content-reader-key.json" && \
  export GWS_CONTENT_READER_CREDENTIALS="$HOME/.cache/gcp/gws-content-reader-key.json" && \
  _SECRETS_LOADED=1 && \
  echo "Secrets loaded." || echo "Failed to load secrets — is 1Password unlocked?"
}
