# --- Source Common Configuration ---
if [ -f "$HOME/.common_profile" ]; then
    . "$HOME/.common_profile"
fi

# --- Zsh Specifics ---

# Path to your oh-my-zsh installation
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"
plugins=(git)

source $ZSH/oh-my-zsh.sh

# Canonicalize PATH (zsh-specific: make path array unique)
typeset -U path PATH

# --- Completions ---
autoload -Uz compinit
zstyle ':completion:*' menu select
compinit
fpath+=~/.zfunc

# Google Cloud SDK Completion
if [ -f "{{ .chezmoi.homeDir }}/google-cloud-sdk/completion.zsh.inc" ]; then
    . "{{ .chezmoi.homeDir }}/google-cloud-sdk/completion.zsh.inc"
fi

# --- Tool integrations ---

# Atuin (shell history)
[ -x "$(command -v atuin)" ] && eval "$(atuin init zsh)"

# Zoxide (smart cd)
eval "$(zoxide init zsh)"

# Direnv (per-directory env)
eval "$(direnv hook zsh)"

# Mise (runtime version manager)
eval "$(mise activate zsh)"

# Carapace (completion engine)
source <(carapace _carapace)
eval "$(carapace _carapace)"

# fzf (fuzzy finder)
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Starship prompt
export SHELL_LABEL="zsh ${ZSH_VERSION}"
eval "$(starship init zsh)"

# Zsh Autosuggestions
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
